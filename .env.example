# Copy this file to .env.local and fill in values.
# .env.local is git-ignored.

# --- Supabase (étape 1 / roadmap) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- YouTube Data API (étape 5 / scraping) ---
YOUTUBE_API_KEY=

# --- Cron auth (étape 5) ---
CRON_SECRET=

# --- Web Push (étape 6) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- E2E auth (étape 4 / Playwright) ---
# Compte Supabase confirmé dédié aux tests. Si vide, le golden path auth est skippé.
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=
