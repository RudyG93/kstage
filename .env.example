# Copy this file to .env.local and fill in values.
# .env.local is git-ignored.

# --- Supabase (étape 1 / roadmap) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- YouTube Data API (étape 5 / scraping) ---
YOUTUBE_API_KEY=

# --- Cron auth (étape 5) ---
CRON_SECRET=

# --- Web Push (étape 6) ---
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# Même valeur que VAPID_PUBLIC_KEY, exposée au client pour l'abonnement.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Admin / modération (étape 8) ---
# Emails admin séparés par des virgules (server-only, jamais exposé client).
# Ces comptes peuvent valider/rejeter les suggestions communautaires.
ADMIN_EMAILS=

# --- E2E auth (étape 4 / Playwright) ---
# Compte Supabase confirmé dédié aux tests. Si vide, le golden path auth est skippé.
E2E_AUTH_EMAIL=
E2E_AUTH_PASSWORD=

# --- Spotify Web API (phase 3 / popularité + images) ---
# Client-credentials (sans login user) : developer.spotify.com/dashboard → Create app.
# Server-only, jamais exposé client.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Cloudinary (phase 3 / recadrage visage via fetch) ---
# Cloud name public, utilisé dans les URLs de livraison (g_auto/g_faces).
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
