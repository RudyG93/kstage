  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md}": "prettier --write",
    "*.{ts,tsx}": "eslint --fix"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@icons-pack/react-simple-icons": "^13.11.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
